# === Local development .env (copy this file to .env and fill values) ===
# .env is gitignored — never commit real secrets.
# For production (Render etc.): set everything in the dashboard.
# See README and render.yaml for details.

# xAI Grok API (required)
XAI_API_KEY=xai-your-key-here

# ElevenLabs (optional — only if you want to offer "included" managed TTS minutes)
# Most users will just use free high-quality local system voices.
ELEVENLABS_API_KEY=

# Basic server config
PORT=8787
NODE_ENV=development

# === Stripe (required for paid subscriptions) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # ID of your recurring Beta Pro price

# === Resend (for magic-link login emails - REQUIRED for tester signup and login links) ===
# 1. Sign up at https://resend.com and get your API key (starts with re_...)
RESEND_API_KEY=re_...

# 2. To send FROM your custom domain (no-reply@thewordincontext.org) instead of Resend's default:
#    - In Resend dashboard → Domains → Add Domain → thewordincontext.org
#    - It will give you DNS records to add at your registrar (Namecheap etc.):
#      * Verification: usually a _resend TXT record
#      * DKIM: resend._domainkey.<yourdomain> CNAME record  <--- this is the one you mentioned
#      * SPF: TXT record on the domain itself
#    - Add ALL of them exactly as shown.
#    - Wait for DNS propagation (use tools like dnschecker.org), then click "Verify" in Resend.
#    - Once "Verified", emails will send from your domain and have better deliverability (less spam).
#    - The "resend._domainkey" is NOT an API key — it's just the DKIM DNS record for authentication.
#    There is a separate RESEND_API_KEY (the re_ one) that goes in the env var above.

# 4. FROM_EMAIL (optional, defaults to no-reply@thewordincontext.org once domain is verified)
#    For initial testing before your domain is verified in Resend, you can set:
#    FROM_EMAIL=The Word in Context <onboarding@resend.dev>
#    (then switch to your custom domain address after verification)
FROM_EMAIL=The Word in Context <no-reply@thewordincontext.org>

# 5. Important: Set RENDER_EXTERNAL_URL to your live URL so magic links point correctly.

# === Auth & Admin ===
JWT_SECRET=generate-a-long-random-string-here   # e.g. openssl rand -base64 48
ADMIN_PASSWORD=your-strong-admin-password

# === App behavior (non-sensitive) ===
TRIAL_DAYS=7
TESTER_TRIAL_DAYS=14
DEMO_LIMIT=5

# === Production only ===
# RENDER_EXTERNAL_URL=https://thewordincontext.org   # or your onrender URL
# NODE_ENV=production

# === How secrets work ===
# Local: real values live only in your .env file.
# Render: 
#   - Put non-sensitive values (TRIAL_DAYS, DEMO_LIMIT, TESTER_TRIAL_DAYS, NODE_ENV, PORT, RENDER_EXTERNAL_URL, STRIPE_PRICE_ID) directly in the env var table.
#   - Put sensitive values (XAI_API_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, RESEND_API_KEY, JWT_SECRET, ADMIN_PASSWORD, ELEVENLABS_API_KEY) as **Secret** env vars (they stay hidden).
# render.yaml only contains safe structure + defaults. Real secrets are never stored in git or yaml.
