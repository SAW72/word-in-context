# === Local development .env (copy this file to .env and fill values) ===
# .env is gitignored — never commit real secrets.
# For production (Render etc.): set everything in the dashboard.
# See README and render.yaml for details.

# xAI Grok API (required)
XAI_API_KEY=xai-your-key-here

# ElevenLabs (optional — only if you want to offer "included" managed TTS minutes)
# Most users will just use free high-quality local system voices.
ELEVENLABS_API_KEY=

# Basic server config
PORT=8787
NODE_ENV=development

# === Whop (preferred for paid subscriptions) ===
# Monthly + yearly checkout links (both should have 7-day free trial in Whop)
WHOP_CHECKOUT_URL_MONTHLY=https://whop.com/checkout/plan_W9vAA0xyptzgt
WHOP_CHECKOUT_URL_YEARLY=https://whop.com/checkout/plan_xjGkPczz1CWju
# Legacy fallback if only one URL is set:
# WHOP_CHECKOUT_URL=https://whop.com/checkout/plan_hWWAQiPvpAYKN
# All plan IDs Whop may send via webhook (include a 3rd link here if you have one):
WHOP_PLAN_IDS=plan_hWWAQiPvpAYKN,plan_xjGkPczz1CWju,plan_W9vAA0xyptzgt
# From Whop Dashboard → Developer → Webhooks (after creating webhook to /api/whop-webhook)
WHOP_WEBHOOK_SECRET=whsec_...

# Stripe removed — payments are Whop-only. Delete any STRIPE_* vars from Render.

# === Resend (for magic-link login emails - REQUIRED for tester signup and login links) ===
# 1. Sign up at https://resend.com and get your API key (starts with re_...)
RESEND_API_KEY=re_...

# 2. To send FROM your custom domain (no-reply@thewordincontext.org) instead of Resend's default:
#    - In Resend dashboard → Domains → Add Domain → thewordincontext.org
#    - It will give you DNS records to add at your registrar (Namecheap etc.):
#      * Verification: usually a _resend TXT record
#      * DKIM: resend._domainkey.<yourdomain> CNAME record  <--- this is the one you mentioned
#      * SPF: TXT record on the domain itself
#    - Add ALL of them exactly as shown.
#    - Wait for DNS propagation (use tools like dnschecker.org), then click "Verify" in Resend.
#    - Once "Verified", emails will send from your domain and have better deliverability (less spam).
#    - The "resend._domainkey" is NOT an API key — it's just the DKIM DNS record for authentication.
#    There is a separate RESEND_API_KEY (the re_ one) that goes in the env var above.
#
#    Note on "Enable receiving" toggle in Resend domain settings:
#    This is for *inbound* email (Resend receiving emails sent to your domain and routing them).
#    For our app we only *send* outbound magic links, so you can leave "Enable receiving" OFF.
#    Toggling it won't affect sending. "Pending" status after adding DNS records is normal while Resend verifies propagation.

# 4. FROM_EMAIL (optional, defaults to no-reply@thewordincontext.org once domain is verified)
#    For initial testing before your domain is verified in Resend, you can set:
#    FROM_EMAIL=The Word in Context <onboarding@resend.dev>
#    (then switch to your custom domain address after verification)
#
#    Put the full "Display Name <email@address>" format exactly as shown.
#    Do NOT use an address from the "Receiving" section of Resend — that is for inbound email.
#    We only need outbound (magic links), so use the onboarding address while verifying your domain.
#    In Render, set the value WITHOUT surrounding quotes. Use capital "The".
#    For testing (while domain pending): FROM_EMAIL=The Word in Context <onboarding@resend.dev>
FROM_EMAIL=The Word in Context <no-reply@thewordincontext.org>

# --- Email troubleshooting (when tester/magic emails "succeed" in UI but don't arrive) ---
# 1. In Render dashboard, after setting FROM_EMAIL + RESEND_API_KEY (as Secret), trigger a Manual Deploy.
# 2. Submit the tester form (or request-login) on the live site.
# 3. Immediately check the Render Logs for this app:
#    - Look for lines starting [sendMagicLink]
#    - Confirm "actual from value being used: "The Word in Context <onboarding@resend.dev>" "
#    - Look for "Resend accepted send. id=..."  <-- this means Resend took it (good). If instead you see "Resend returned error: ..." then the send was rejected (bad key, bad from format, etc) and the form should now show an error too.
# 4. Go to https://resend.com (your dashboard) → Emails (or the specific domain/project). Find the send by time/to address.
#    - Status may be "Sending", "Delivered", "Bounced", "Complained", or show error.
#    - If not listed at all, the call never reached Resend or was filtered early.
#    - Click the entry for full headers, any rejection reason, etc.
# 5. Check your inbox + SPAM / Promotions / Junk folders (Gmail often routes onboarding@resend.dev here, especially pre-domain-verify).
# 6. Common causes:
#    - FROM_EMAIL set with lowercase "the" or extra quotes/spaces (now normalized in code, but set exactly "The Word in Context <onboarding@resend.dev>" in Render).
#    - Domain still "pending" (use onboarding@ while pending; after verify switch FROM_EMAIL to your @thewordincontext.org).
#    - RESEND_API_KEY wrong region or not the "sending" key.
#    - For unverified domains, Resend may have lower deliverability or additional headers; verify domain + set custom from for best results.
#    - Test by sending to the exact email you used in Resend account signup first.
# 7. Once domain is Verified in Resend + DNS records (incl. the DKIM resend._domainkey) are good, change FROM_EMAIL to "The Word in Context <no-reply@thewordincontext.org>" (or your chosen from address) and redeploy.

# 5. Important: Set RENDER_EXTERNAL_URL to your live URL (custom domain or current onrender) so magic links and Whop checkout redirect point correctly.
# You can keep it as the onrender URL while testing on the render domain, then update to custom when you switch DNS.

# === Auth & Admin ===
JWT_SECRET=generate-a-long-random-string-here   # e.g. openssl rand -base64 48
ADMIN_PASSWORD=your-strong-admin-password

# === App behavior (non-sensitive) ===
TRIAL_DAYS=7
TESTER_TRIAL_DAYS=14
DEMO_LIMIT=5

# === Production only ===
# RENDER_EXTERNAL_URL=https://thewordincontext.org   # or your onrender URL
# NODE_ENV=production

# === How secrets work ===
# Local: real values live only in your .env file.
# Render: 
#   - Put non-sensitive values (TRIAL_DAYS, DEMO_LIMIT, TESTER_TRIAL_DAYS, NODE_ENV, PORT, RENDER_EXTERNAL_URL, STRIPE_PRICE_ID) directly in the env var table.
#   - Put sensitive values (XAI_API_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, RESEND_API_KEY, JWT_SECRET, ADMIN_PASSWORD, ELEVENLABS_API_KEY) as **Secret** env vars (they stay hidden).
# render.yaml only contains safe structure + defaults. Real secrets are never stored in git or yaml.
