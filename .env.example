# Get your key at https://console.grok.com or https://x.ai
XAI_API_KEY=xai-your-key-here

# ElevenLabs key for *managed* voices (used by /api/tts when users don't provide their own key).
# This lets you offer "included" TTS quota in low-monthly-fee subscriptions.
# IMPORTANT: In the app, premium ElevenLabs is OFF by default (users get excellent free local Mac voices).
# Only users who explicitly enable "premium voices" in settings (or paste own key) will use your managed key.
# Use a cheap model + short excerpts (server caps ~280 chars) so costs stay low even with many subs.
# Users can still paste their own key in the UI for unlimited/personal use (their cost).
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: Port (default 8787)
PORT=8787

# For production deploy (Render, Railway, etc.):
# - Set NODE_ENV=production (removes dev CSP/no-cache)
# - Add your real keys via the hosting platform dashboard (never commit secrets)
# - Use a real database later instead of localStorage + betas.json for users/subscriptions

# Stripe (for subscriptions and payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_subscription_price_id   # the recurring price for Beta Pro

# For magic link emails (Resend.com - free tier available)
RESEND_API_KEY=re_your_resend_key

# Simple admin password for /admin control panel (change this!)
ADMIN_PASSWORD=change-this-secure-password

# JWT secret for auth tokens
JWT_SECRET=super-long-random-secret-string-here
